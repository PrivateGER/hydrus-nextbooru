{
  "name": "nextbooru",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "test": "cross-env NODE_OPTIONS='--no-webstorage' vitest run",
    "test:watch": "cross-env NODE_OPTIONS='--no-webstorage' vitest",
    "test:ui": "cross-env NODE_OPTIONS='--no-webstorage' vitest --ui --api 3001",
    "test:coverage": "cross-env NODE_OPTIONS='--no-webstorage' vitest run --coverage",
    "test:coverage:ui": "cross-env NODE_OPTIONS='--no-webstorage' vitest --ui --api 3001 --coverage",
    "test:sync": "cross-env NODE_OPTIONS='--no-webstorage' vitest run src/lib/hydrus/sync",
    "test:integration": "cross-env NODE_OPTIONS='--no-webstorage' vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "cross-env NODE_OPTIONS='--no-webstorage' vitest --config vitest.integration.config.ts",
    "test:guards": "cross-env NODE_OPTIONS='--no-webstorage' vitest run --config vitest.guards.config.ts",
    "test:perf": "cross-env NODE_OPTIONS='--no-webstorage' vitest run --config vitest.perf.config.ts",
    "test:perf:large": "cross-env NODE_OPTIONS='--no-webstorage' PERF_DATASET_SIZE=large vitest run --config vitest.perf.config.ts",
    "test:all": "npm run test && npm run test:integration"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/otel": "^2.1.0",
    "blurhash": "^2.0.5",
    "dotenv": "^17.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "isomorphic-dompurify": "^3.18.0",
    "marked": "^18.0.5",
    "next": "16.2.10",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3",
    "sql-formatter": "^15.7.2"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testcontainers/postgresql": "12.0.4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.5",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "memfs": "^4.56.10",
    "msw": "^2.12.10",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "testcontainers": "12.0.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vitest-mock-extended": "^4.0.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "postcss": "8.5.16",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
