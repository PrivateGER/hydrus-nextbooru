# Booru Environment Configuration
# Copy this file to .env and update with your values
# NEVER commit .env to version control

# Database Configuration
# Generate a strong URL-safe password: openssl rand -hex 32
POSTGRES_USER=booru
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=booru

# Site Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000 # Public URL of your site (for metadata/OG images)
ADMIN_PASSWORD=supersecretpassword # Minimum 16 characters

# Hydrus Integration
HYDRUS_API_URL=http://localhost:45869
HYDRUS_API_KEY=your_hydrus_api_key_here

# Keep this path the same if using Docker stack
HYDRUS_FILES_PATH=/hydrus

# OCR sidecar (optional) - positioned text recognition & translation overlay
# Run the manga-image-translator service (see docker-compose.yml) and set:
# OCR_SERVICE_URL=http://ocr:8000
# OCR_SERVICE_TIMEOUT_MS=120000
# Attach the page image to the translation call for visual context (needs a
# vision-capable model; best paired with a locally hosted VLM). Off by default.
# OCR_TRANSLATION_VISION_CONTEXT=true
# OCR_TRANSLATION_VISION_CONTEXT_SIZE=1024

# Tracing (OpenTelemetry) - Optional
# Set to enable distributed tracing for observability
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # OTLP HTTP endpoint (e.g., Jaeger)
# NEXT_OTEL_VERBOSE=1  # Enable verbose tracing (includes more spans)
